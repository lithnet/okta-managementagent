<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<clear />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
		<add key="LithnetPrivatePackages" value="https://pkgs.dev.azure.com/lithnet/_packaging/LithnetPrivatePackages/nuget/v3/index.json" />
		<!-- Dev/test ONLY: the local package feed produced by the side-by-side ecma2-framework repo
		     (dotnet pack into <ecma2-framework>\artifacts\nupkg). This lets the MA consume the
		     Lithnet.Ecma2Framework holding package (and its transitive Sdk/Hosting deps) from a locally
		     built .nupkg instead of a project reference, exercising the real customer package path before
		     the framework is published. The two repos sit side by side under D:\dev\git\lithnet\, so the
		     path is relative. Remove (or point at the published feed) once the framework ships. -->
		<add key="Ecma2FrameworkLocal" value="..\..\ecma2-framework\artifacts\nupkg" />
	</packageSources>
	<packageSourceMapping>
		<!-- The locally built framework packages resolve from the local dev feed. This pattern is more
		     specific than the general 'Lithnet.*' below, so NuGet routes the framework holding/Sdk/Hosting
		     packages here while every other Lithnet.* package still comes from the private feed. -->
		<packageSource key="Ecma2FrameworkLocal">
			<package pattern="Lithnet.Ecma2Framework*" />
		</packageSource>
		<packageSource key="LithnetPrivatePackages">
			<package pattern="Lithnet.*" />
		</packageSource>
		<packageSource key="nuget.org">
			<package pattern="*" />
		</packageSource>
	</packageSourceMapping>
</configuration>
